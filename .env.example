# Bank API credentials (required for API calls)
VITE_BANK_CODE=068
VITE_API_VENDOR=MOBILE
VITE_API_USERNAME=MOBILE
VITE_API_PASSWORD=
VITE_API_SECRET_KEY=
VITE_API_CHANNEL=WB

# API base URL — leave EMPTY for production/UAT (uses same-origin /dmCmsService via nginx)
# Only set for local dev if you need a custom proxy target path
VITE_API_BASE=

# Dev-only: optional fallbacks when testing without URL params (npm run dev)
VITE_DEV_CUSTOMER_ID=
VITE_DEV_MOBILE_NO=

# PI encryption — keys must match backend PemKeyLoader (rsa.public.key / rsa.private.key)
VITE_PI_ENCRYPTION_ENABLED=false
# X509 SPKI PEM — same content as backend public key file
VITE_RSA_PUBLIC_KEY=
# PKCS#8 PEM — same content as backend private key file
VITE_RSA_PRIVATE_KEY=
# Optional; defaults to /whatsapp/cmrequest/cmdataprocessing
VITE_ENCRYPTED_API_PATH=
