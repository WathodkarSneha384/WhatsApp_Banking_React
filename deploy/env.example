# Copy to project root as `.env` before npm run build / npm run dev
# cp deploy/env.example .env

VITE_BANK_CODE=068
VITE_API_VENDOR=MOBILE
VITE_API_USERNAME=MOBILE
VITE_API_PASSWORD=your_password_here
VITE_API_SECRET_KEY=your_secret_key_here
VITE_API_CHANNEL=WB

# Leave EMPTY for UAT/production — API uses same-origin /dmCmsService (nginx proxy)
VITE_API_BASE=

  // Optional — redirect to WhatsApp when session expires (after trying to close the webview).
  // Leave empty to only close the app. Example: https://wa.me/<countrycode><number>
  VITE_WHATSAPP_RETURN_URL=

# PI encryption (Channel Manager cmdataprocessing) — set true when backend requires encrypted payloads
VITE_PI_ENCRYPTION_ENABLED=false
# Leave empty to auto-select: /whatsapp/... (dev) or /dmCmsService/whatsapp/... (production build)
VITE_ENCRYPTED_API_PATH=
# RSA private key PEM for decrypting responses (use \n for line breaks in .env)
VITE_RSA_PRIVATE_KEY=
# Optional override — defaults to bundled public key from backend team
VITE_RSA_PUBLIC_KEY=

# Dev-only fallbacks when URL has no customerId/mobile (optional)
VITE_DEV_CUSTOMER_ID=
VITE_DEV_MOBILE_NO=
